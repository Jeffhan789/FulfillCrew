# ---------------------------------------------------------------------------
# FulfillCrew Environment Variables
# ---------------------------------------------------------------------------
# Copy this file to .env and adjust values as needed.
#
# BACKEND_LOG_LEVEL: debug | info | warning | error
BACKEND_LOG_LEVEL=info

# BACKEND_PORT: The port the FastAPI backend listens on inside the container.
BACKEND_PORT=8000

# FRONTEND_PORT: The port the Nginx frontend listens on (host mapping).
FRONTEND_PORT=80

# API_BASE_URL: The base URL used by the frontend to reach the backend.
# In Docker Compose, the frontend proxy routes /api/* to the backend service.
# For local development without Docker, set this to http://127.0.0.1:8000
API_BASE_URL=http://127.0.0.1:8000

# CORS_ORIGINS: Comma-separated list of allowed CORS origins.
# Add any additional frontend URLs here.
CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173,http://localhost,http://127.0.0.1,http://localhost:8080
